# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Base URL of the app (used for redirects and reset-password links)
APP_URL=http://localhost:5000

# SMTP (used to send "forgot password" emails)
# Example values for Gmail: host=smtp.gmail.com, port=587, use TLS,
# and use an "App Password" (not your normal Gmail password) for MAIL_PASSWORD.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=ONDA Essaouira <your-email@gmail.com>
